# ============================================================
# THE MALIN MADNESS — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# These same variables must be added in your Vercel project
# dashboard under Settings → Environment Variables.
# ============================================================

# --- Vercel Postgres ---
# These are automatically injected when you link a Vercel
# Postgres database in your project dashboard.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# --- Cloudinary ---
# Found at: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Next.js public env (safe to expose to browser)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Password Protection ---
# The single shared password your family uses to log in
FAMILY_PASSWORD=
